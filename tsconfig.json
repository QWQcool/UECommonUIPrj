{
    "compilerOptions": {
        "target": "esnext",
        "module": "commonjs",
		"experimentalDecorators": true, // Set `true` to use of Decorators (i.e. RPC functions)
        "jsx": "react",
        "sourceMap": true,
        "strict": true,
        "typeRoots": [
            "Typing",
            "./node_modules/@types"
        ],
        "rootDir": "TypeScript",
        "outDir": "Content/JavaScript"
    },
    "include": [
        "TypeScript/**/*"
    ]
}